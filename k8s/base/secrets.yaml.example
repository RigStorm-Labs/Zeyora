apiVersion: v1
kind: Secret
metadata:
  name: zeyora-secrets
type: Opaque
stringData:
  database-url: postgresql://user:password@postgres:5432/zeyora
  jwt-secret: your-super-secret-jwt-key
  jwt-refresh-secret: your-super-secret-refresh-key
  razorpay-key-id: your-razorpay-key
  razorpay-key-secret: your-razorpay-secret
